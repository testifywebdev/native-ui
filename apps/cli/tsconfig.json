{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "inlineSourceMap": false,
    "types": ["node"]
  },
  "include": ["src/**/*", "tsconfig.json"],
  "exclude": ["node_modules", "dist"]
}
